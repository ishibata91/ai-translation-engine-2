package llm

import (
	"log/slog"

	base "github.com/ishibata91/ai-translation-engine-2/pkg/gateway/llm"
)

// Manager aliases the concrete LLM manager used by composition root.
type Manager = base.Manager

// NewLLMManager constructs the default LLM gateway manager.
func NewLLMManager(logger *slog.Logger) LLMManager {
	return base.NewLLMManager(logger)
}
